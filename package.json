{
  "name": "@interline-io/tlv2-ui",
  "version": "0.0.0",
  "repository": "https://github.com/interline-io/tlv2-ui",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "prepack": "pnpm run generate:types && nuxt-module-build prepare && nuxt-module-build build",
    "dev": "pnpm run dev:prepare && nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "generate:types": "tsx scripts/generate-component-types.ts",
    "check": "pnpm lint --fix && pnpm nuxt typecheck && pnpm test",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./lib/auth": {
      "types": "./dist/runtime/lib/auth/index.d.ts",
      "import": "./dist/runtime/lib/auth/index.js"
    },
    "./lib/analytics": {
      "types": "./dist/runtime/lib/analytics/index.d.ts",
      "import": "./dist/runtime/lib/analytics/index.js"
    },
    "./lib/config": {
      "types": "./dist/runtime/lib/config/index.d.ts",
      "import": "./dist/runtime/lib/config/index.js"
    },
    "./lib/testutil": {
      "types": "./dist/runtime/lib/testutil/index.d.ts",
      "import": "./dist/runtime/lib/testutil/index.js"
    },
    "./lib/gtfs": {
      "types": "./dist/runtime/lib/gtfs/index.d.ts",
      "import": "./dist/runtime/lib/gtfs/index.js"
    },
    "./lib/util": {
      "types": "./dist/runtime/lib/util/index.d.ts",
      "import": "./dist/runtime/lib/util/index.js"
    }
  },
  "main": "./dist/module.mjs",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "devDependencies": {
    "@nuxt/cli": "3.30.0",
    "@nuxt/devtools": "3.0.1",
