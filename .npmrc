# pnpm: hoist as many dependencies as possible to root node_modules.
# Required because Vite needs to resolve transitive deps from the project root
# during dev pre-bundling, and many packages (Apollo, vega, cytoscape, etc.)
# have deep dependency trees that pnpm's strict layout doesn't expose.
# This only affects local dev — consumers of the published module are not affected.
shamefully-hoist=true
